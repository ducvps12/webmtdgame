<div class="toast-container" id="toastContainer"></div>

<script>
let currentPage = 1;
let currentStatus = '';

function formatMoney(n) { return new Intl.NumberFormat('vi-VN').format(n); }

function formatTime(t) {
    if (!t) return '-';
    const d = new Date(t);
    if (isNaN(d.getTime())) return t;
    return d.toLocaleString('vi-VN', {day:'2-digit',month:'2-digit',year:'2-digit',hour:'2-digit',minute:'2-digit'});
}

function statusBadge(s) {
    const map = {
        'success': '<span class="badge badge-success">âœ“ ThÃ nh cÃ´ng</span>',
        'ignored': '<span class="badge badge-muted">â€” Bá» qua</span>',
        'failed': '<span class="badge badge-danger">âœ— Tháº¥t báº¡i</span>',
        'pending': '<span class="badge badge-warning">â³ Chá»</span>'
    };
    return map[s] || s;
}

function showToast(msg, type='info') {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = 'toast ' + type;
    t.textContent = msg;
    c.appendChild(t);
    setTimeout(() => t.remove(), 4000);
}

function setFilter(btn, status) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentStatus = status;
    currentPage = 1;
    loadTransactions();
}

function loadTransactions() {
    fetch(`/admin/api.php?action=get_transactions&status=${currentStatus}&page=${currentPage}`)
        .then(r => r.json())
        .then(res => {
            if (res.status !== 'success') return;

            document.getElementById('txCount').textContent = `Tá»•ng: ${res.total} giao dá»‹ch`;

            const tbody = document.getElementById('txTable');
            if (res.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="empty-state" style="padding:40px"><i class="bi bi-inbox"></i><p>ChÆ°a cÃ³ giao dá»‹ch</p></td></tr>';
            } else {
                tbody.innerHTML = res.data.map(tx => `
                    <tr>
                        <td class="text-white">#${tx.transaction_number}</td>
                        <td><span class="text-money">${formatMoney(tx.amount)}Ä‘</span></td>
                        <td>${tx.sender_name || '-'}</td>
                        <td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${(tx.description || '').replace(/"/g, '&quot;')}">${tx.description || '-'}</td>
                        <td>${tx.matched_username ? '<span class="text-username">' + tx.matched_username + '</span>' : '<span style="color:var(--text-muted)">-</span>'}</td>
                        <td>${statusBadge(tx.status)}</td>
                        <td>${formatTime(tx.created_at)}</td>
                    </tr>
                `).join('');
            }

            // Pagination
            const pagDiv = document.getElementById('pagination');
            if (res.pages <= 1) { pagDiv.innerHTML = ''; return; }
            let html = '';
            if (currentPage > 1) html += `<button class="page-btn" onclick="currentPage=1;loadTransactions()">Â«</button>`;
            for (let i = Math.max(1, currentPage-2); i <= Math.min(res.pages, currentPage+2); i++) {
                html += `<button class="page-btn ${i === res.page ? 'active' : ''}" onclick="currentPage=${i};loadTransactions()">${i}</button>`;
            }
            if (currentPage < res.pages) html += `<button class="page-btn" onclick="currentPage=${res.pages};loadTransactions()">Â»</button>`;
            pagDiv.innerHTML = html;
        });
}

function checkATM() {
    fetch('/admin/api.php?action=check_atm')
        .then(r => r.json())
        .then(res => {
            if (res.status === 'success') {
                showToast(res.message, 'success');
                loadTransactions();
            } else {
                showToast(res.message || 'Lá»—i', 'error');
            }
        });
}

document.addEventListener('DOMContentLoaded', loadTransactions);
</script>

</body>
</html>


