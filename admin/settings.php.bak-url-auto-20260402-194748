<div class="toast-container" id="toastContainer"></div>

<script>
function switchTab(tab, btn) {
    document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
    document.querySelectorAll('.settings-tab').forEach(function(t) { t.classList.remove('active'); });
    document.getElementById('tab-' + tab).classList.add('active');
    btn.classList.add('active');
}

function showToast(msg, type) {
    var c = document.getElementById('toastContainer');
    var t = document.createElement('div');
    t.className = 'toast ' + (type || 'info');
    t.textContent = msg;
    c.appendChild(t);
    setTimeout(function() { t.remove(); }, 4000);
}

function updateSeoCounter() {
    var el = document.getElementById('cfg_SITE_DESCRIPTION');
    var hint = document.getElementById('seoDescHint');
    if (!el || !hint) return;
    var len = (el.value || '').trim().length;
    var status = (len >= 140 && len <= 160) ? 'Tốt' : 'Cần tối ưu';
    hint.textContent = 'Độ dài: ' + len + '/160 ký tự - ' + status;
}

function generateSeoDescription() {
    var titleEl = document.getElementById('cfg_SITE_TITLE');
    var keywordEl = document.getElementById('cfg_SITE_KEYWORDS');
    var descEl = document.getElementById('cfg_SITE_DESCRIPTION');
    if (!titleEl || !keywordEl || !descEl) return;

    var title = (titleEl.value || 'Chú Bé Rồng Online').trim();
    var keywords = (keywordEl.value || 'ngọc rồng, NRO, game dragon ball').split(',').map(function(v){ return v.trim(); }).filter(Boolean);
    var keywordText = keywords.slice(0, 3).join(', ');
    var draft = title + ' - Máy chủ game nhập vai Dragon Ball online ổn định, nạp ATM tự động nhanh, cộng tiền tức thì, cộng đồng đông đảo.';
    if (keywordText) {
        draft += ' Từ khóa: ' + keywordText + '.';
    }
    if (draft.length > 160) draft = draft.slice(0, 157).trim() + '...';
    descEl.value = draft;
    updateSeoCounter();
}

function saveSettings(group) {
    var settings = {};
    var fields = [];

    if (group === 'general') {
        fields = ['DOMAIN', 'IP', 'SITE_TITLE', 'SITE_DESCRIPTION', 'SITE_KEYWORDS', 'ZALO_LINK', 'FACEBOOK_LINK'];
        // Handle maintenance mode toggle
        settings['MAINTENANCE_MODE'] = document.getElementById('cfg_MAINTENANCE_MODE').checked ? '1' : '0';
    } else if (group === 'atm') {
        fields = ['BANK_NAME', 'ACB_ACCOUNT', 'ACB_TOKEN', 'ACB_API_URL', 'ATM_PREFIX', 'ACCOUNT_HOLDER', 'MIN_DEPOSIT'];
    } else if (group === 'appearance') {
        fields = ['HERO_TITLE', 'HERO_SUBTITLE', 'FOOTER_TEXT', 'DISCORD_LINK'];
    } else if (group === 'cron') {
        fields = ['CRON_URL'];
    } else if (group === 'game') {
        fields = ['GAME_SERVER_IP', 'GAME_SERVER_PORT'];
    }

    fields.forEach(function(f) {
        var el = document.getElementById('cfg_' + f);
        if (el) settings[f] = el.value;
    });

    var formData = new FormData();
    formData.append('action', 'save_settings');
    Object.keys(settings).forEach(function(k) {
        formData.append('settings[' + k + ']', settings[k]);
    });

    fetch('/admin/api.php', { method: 'POST', body: formData })
        .then(function(r) { return r.json(); })
        .then(function(res) {
            showToast(res.message, res.status === 'success' ? 'success' : 'error');
        })
        .catch(function(e) { showToast('Lỗi: ' + e.message, 'error'); });
}

function testAPI() {
    var statusDiv = document.getElementById('apiStatus');
    if (statusDiv) {
        statusDiv.innerHTML = '<div style="text-align:center"><div class="spinner"></div><div style="margin-top:10px;font-size:13px;color:var(--text-muted)">Đang kiểm tra...</div></div>';
    }
    fetch('/admin/api.php?action=check_atm')
        .then(function(r) { return r.json(); })
        .then(function(res) {
            if (!statusDiv) { showToast(res.message, res.status); return; }
            if (res.status === 'success') {
                statusDiv.innerHTML = '<div style="text-align:center;width:100%"><div style="font-size:42px;margin-bottom:10px">✅</div><div style="color:var(--accent-green);font-weight:600;font-size:15px;margin-bottom:6px">Kết nối thành công!</div><div style="color:var(--text-secondary);font-size:12px">' + res.message + '</div></div>';
            } else {
                statusDiv.innerHTML = '<div style="text-align:center;width:100%"><div style="font-size:42px;margin-bottom:10px">❌</div><div style="color:var(--accent-red);font-weight:600;font-size:15px;margin-bottom:6px">Lỗi kết nối</div><div style="color:var(--text-secondary);font-size:12px">' + res.message + '</div></div>';
            }
            showToast(res.message, res.status === 'success' ? 'success' : 'error');
        })
        .catch(function(e) { showToast('Lỗi kết nối: ' + e.message, 'error'); });
}

function checkGameServer() {
    var container = document.getElementById('gameServerStatus');
    var ip = document.getElementById('cfg_GAME_SERVER_IP')?.value || '<?php echo htmlspecialchars($cfg['IP'] ?? ''); ?>';
    var port = document.getElementById('cfg_GAME_SERVER_PORT')?.value || '<?php echo htmlspecialchars($cfg['GAME_SERVER_PORT'] ?? '14445'); ?>';
    container.innerHTML = '<div style="text-align:center;padding:20px"><div class="spinner"></div><div style="margin-top:8px;color:var(--text-muted);font-size:13px">Đang kiểm tra ' + ip + ':' + port + '...</div></div>';

    // Simple check via API
    fetch('/admin/api.php?action=check_game_server&ip=' + encodeURIComponent(ip) + '&port=' + encodeURIComponent(port))
        .then(function(r) { return r.json(); })
        .then(function(res) {
            if (res.status === 'success') {
                container.innerHTML = '<div style="text-align:center;padding:20px"><div style="font-size:42px;margin-bottom:8px">🟢</div><div style="color:var(--accent-green);font-weight:600;font-size:14px">Server Online</div><div style="color:var(--text-muted);font-size:12px;margin-top:4px">' + ip + ':' + port + '</div></div>';
            } else {
                container.innerHTML = '<div style="text-align:center;padding:20px"><div style="font-size:42px;margin-bottom:8px">🔴</div><div style="color:var(--accent-red);font-weight:600;font-size:14px">Server Offline</div><div style="color:var(--text-muted);font-size:12px;margin-top:4px">' + (res.message || 'Không thể kết nối') + '</div></div>';
            }
        })
        .catch(function() {
            container.innerHTML = '<div style="text-align:center;padding:20px"><div style="font-size:42px;margin-bottom:8px">⚠️</div><div style="color:var(--accent-orange);font-weight:600;font-size:14px">Không xác định</div><div style="color:var(--text-muted);font-size:12px;margin-top:4px">Lỗi kết nối API</div></div>';
        });
}

function copyText(text) {
    navigator.clipboard.writeText(text).then(function() {
        showToast('Đã sao chép!', 'success');
    });
}

document.addEventListener('DOMContentLoaded', function() {
    var seoInput = document.getElementById('cfg_SITE_DESCRIPTION');
    if (seoInput) {
        seoInput.addEventListener('input', updateSeoCounter);
        updateSeoCounter();
    }
});
</script>

