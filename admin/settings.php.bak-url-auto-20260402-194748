<?php
// admin/settings.php - Comprehensive System Settings
if (session_status() === PHP_SESSION_NONE) { session_start(); }
require_once __DIR__ . '/../connect.php';
require_once __DIR__ . '/../env.php';

if (!isset($_SESSION['username'])) { header('Location: /login'); exit; }
$stmt = $conn->prepare("SELECT id, username, is_admin FROM account WHERE username = ? LIMIT 1");
$stmt->bind_param("s", $_SESSION['username']);
$stmt->execute();
$admin_user = $stmt->get_result()->fetch_assoc();
$stmt->close();
if (!$admin_user || $admin_user['is_admin'] != 1) { header('Location: /'); exit; }

$admin_username = htmlspecialchars($admin_user['username']);
$cfg = $_ENV_CONFIG;

// DB stats
$db_stats = [];
$r = $conn->query("SELECT COUNT(*) as c FROM account"); $db_stats['accounts'] = $r->fetch_assoc()['c'];
$r = $conn->query("SELECT COUNT(*) as c FROM player"); $db_stats['players'] = $r->fetch_assoc()['c'];
$r = $conn->query("SELECT COUNT(*) as c FROM bank_transactions"); $db_stats['tx_total'] = $r->fetch_assoc()['c'];
$r = $conn->query("SELECT COUNT(*) as c FROM bank_transactions WHERE status='success'"); $db_stats['tx_success'] = $r->fetch_assoc()['c'];
$r = $conn->query("SELECT COALESCE(SUM(amount),0) as s FROM bank_transactions WHERE status='success'"); $db_stats['revenue'] = $r->fetch_assoc()['s'];
?>
